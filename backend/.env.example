# Copia questo file in ".env" e compila i valori. NON committare il .env reale.

# Database PostgreSQL (es. Neon, Supabase, locale...)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT — usa stringhe lunghe e casuali (obbligatorie se NODE_ENV=production)
JWT_SECRET=cambia-questo-secret
JWT_REFRESH_SECRET=cambia-questo-refresh-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Origine del frontend autorizzata (CORS). In locale: http://localhost:4200
CORS_ORIGIN=http://localhost:4200
